# EditorConfig https://EditorConfig.org

# top-most EditorConfig file
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{ts,tsx}]
indent_style = space
indent_size = 2
tab_size = 2


